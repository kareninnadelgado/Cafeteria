@page "/admin-tools"
@rendermode InteractiveServer
@using Cafeteria.Models
@inject Cafeteria.Services.FirebaseAuthService AuthService
@inject Cafeteria.Services.AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Panel de Administración - Cafetería</PageTitle>

<MudThemeProvider />
<MudLayout>
    <MudContainer MaxWidth="MaxWidth.Medium" Class="py-4">
        
        @if (estaVerificando)
        {
            <div class="d-flex justify-content-center mt-8">
                <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Default" Class="mt-3 text-center">
                    Verificando acceso...
                </MudText>
            </div>
        }
        else if (!esAdmin)
        {
            <MudPaper Class="pa-6 text-center" Style="border-radius: 20px;">
                <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Error" Class="mb-3" Style="font-size: 64px;" />
                <MudText Typo="Typo.h4" Color="Color.Error" Class="mb-2 font-weight-bold">
                    Acceso Denegado
                </MudText>
                <MudText Typo="Typo.body1" Color="Color.Default" Class="mb-4">
                    No tienes permisos para acceder a esta página.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick='() => Navigation.NavigateTo("/")' Size="Size.Large">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Class="mr-2" /> Volver al Menú
                </MudButton>
            </MudPaper>
        }
        else
        {
            <!-- Header -->
            <MudStack AlignItems="AlignItems.Center" Class="mb-5">
                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" 
                         Color="Color.Primary" 
                         Size="Size.Large" 
                         Style="font-size: 48px;" />
                <MudText Typo="Typo.h3" Align="Align.Center" Class="font-weight-bold">
                    Panel de Administración
                </MudText>
                <MudText Typo="Typo.subtitle1" Align="Align.Center" Color="Color.Default">
                    Gestiona la cafetería escolar
                </MudText>
            </MudStack>

            <!-- Grid de tarjetas admin -->
            <MudGrid Spacing="3" Justify="Justify.Center">
                
                <!-- Menú - Gestión de productos -->
                <MudItem xs="12" sm="6" md="6">
                    <MudCard Elevation="2" 
                             ElevationHover="6"
                             Class="admin-card"
                             Style="border-radius: 20px; cursor: pointer; height: 100%; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);"
                             @onclick='() => Navigation.NavigateTo("/")'>
                        <MudCardContent Class="pa-6 text-center">
                            <MudIcon Icon="@Icons.Material.Filled.RestaurantMenu" 
                                     Size="Size.Large" 
                                     Color="Color.Primary" 
                                     Class="mb-3"
                                     Style="font-size: 48px;" />
                            <MudText Typo="Typo.h5" Class="mb-2 font-weight-medium">
                                Menú
                            </MudText>
                            <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-3">
                                Ver, editar, eliminar y gestionar todos los productos del menú
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                CRUD completo
                            </MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <!-- Añadir nuevo producto -->
                <MudItem xs="12" sm="6" md="6">
                    <MudCard Elevation="2" 
                             ElevationHover="6"
                             Class="admin-card"
                             Style="border-radius: 20px; cursor: pointer; height: 100%; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);"
                             @onclick='() => Navigation.NavigateTo("/admin/producto/nuevo")'>
                        <MudCardContent Class="pa-6 text-center">
                            <MudIcon Icon="@Icons.Material.Filled.AddCircle" 
                                     Size="Size.Large" 
                                     Color="Color.Success" 
                                     Class="mb-3"
                                     Style="font-size: 48px;" />
                            <MudText Typo="Typo.h5" Class="mb-2 font-weight-medium">
                                Añadir Producto
                            </MudText>
                            <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-3">
                                Agregar un nuevo producto al menú con imagen, precio y personalizaciones
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                                Nuevo
                            </MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <!-- Registro de usuarios -->
                <MudItem xs="12" sm="6" md="6">
                    <MudCard Elevation="2" 
                             ElevationHover="6"
                             Class="admin-card"
                             Style="border-radius: 20px; cursor: pointer; height: 100%; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);"
                             @onclick='() => Navigation.NavigateTo("/admin/registros")'>
                        <MudCardContent Class="pa-6 text-center">
                            <MudIcon Icon="@Icons.Material.Filled.People" 
                                     Size="Size.Large" 
                                     Color="Color.Secondary" 
                                     Class="mb-3"
                                     Style="font-size: 48px;" />
                            <MudText Typo="Typo.h5" Class="mb-2 font-weight-medium">
                                Registro de Usuarios
                            </MudText>
                            <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-3">
                                Ver todos los usuarios registrados, sus pedidos y estadísticas
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">
                                Gestión de usuarios
                            </MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <!-- Otros / Configuración -->
                <MudItem xs="12" sm="6" md="6">
                    <MudCard Elevation="2" 
                             ElevationHover="6"
                             Class="admin-card"
                             Style="border-radius: 20px; cursor: pointer; height: 100%; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);"
                             @onclick='() => Navigation.NavigateTo("/admin/otros")'>
                        <MudCardContent Class="pa-6 text-center">
                            <MudIcon Icon="@Icons.Material.Filled.Settings" 
                                     Size="Size.Large" 
                                     Color="Color.Default" 
                                     Class="mb-3"
                                     Style="font-size: 48px;" />
                            <MudText Typo="Typo.h5" Class="mb-2 font-weight-medium">
                                Otros
                            </MudText>
                            <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-3">
                                Configuración, reportes, personalizaciones globales y más opciones
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                Configuración
                            </MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        }
    </MudContainer>
</MudLayout>

<style>
    /* Efecto de escala al hacer clic (Material Design tactile feedback) */
    .admin-card:active {
        transform: scale(0.98);
    }
    
    /* Focus visible para accesibilidad */
    .admin-card:focus-visible,
    .mud-button-root:focus-visible {
        outline: 2px solid var(--mud-palette-primary);
        outline-offset: 2px;
    }
</style>

@code {
    private bool esAdmin = false;
    private bool estaVerificando = true;
    private bool primeraVez = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && primeraVez)
        {
            primeraVez = false;
            Console.WriteLine("=== AdminTools - Cargando sesión en OnAfterRender ===");
            
            await AuthState.CargarSesionDesdeLocalStorage();
            
            Console.WriteLine($"CurrentUserId: {AuthState.CurrentUserId}");
            Console.WriteLine($"CurrentUserRol: {AuthState.CurrentUserRol}");
            
            var usuario = AuthState.ObtenerUsuarioActual();
            
            if (usuario != null && string.Equals(usuario.Rol, "admin", StringComparison.OrdinalIgnoreCase))
            {
                esAdmin = true;
                Console.WriteLine("✅ ES ADMIN, mostrando panel");
            }
            else
            {
                Console.WriteLine("❌ NO ES ADMIN, redirigiendo");
                Navigation.NavigateTo("/", true);
                return;
            }
            
            estaVerificando = false;
            StateHasChanged();
        }
    }
}