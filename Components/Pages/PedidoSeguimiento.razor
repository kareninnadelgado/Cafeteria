@page "/pedido-seguimiento"
@using MudBlazor
@using Cafeteria.Components.Pages
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
    <MudPaper Elevation="3" Class="pa-6 text-center" Style="border-radius: 24px;">
        <MudStack AlignItems="AlignItems.Center" Spacing="1" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Primary" Size="Size.Large" Style="font-size: 56px;" />
            <MudText Typo="Typo.h5" Color="Color.Primary"><b>Estado de tu Orden</b></MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Tu pedido está siendo procesado en cocina.</MudText>
        </MudStack>

        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-6" Icon="@Icons.Material.Filled.Info" Style="border-radius: 12px;">
            Puedes seguir viendo el proceso de tu pedido en esta pantalla mientras te diviertes.
        </MudAlert>

        <!-- Invocación del componente compartido -->
        <JuegoNutricion />
        
        <MudDivider Class="my-6" />

        <MudButton Variant="Variant.Text" 
                   StartIcon="@Icons.Material.Filled.ArrowBack" 
                   Color="Color.Default" 
                   OnClick='() => Navigation.NavigateTo("/mis-pedidos")'
                   Style="border-radius: 12px;">
            Regresar a Mis Pedidos
        </MudButton>
    </MudPaper>
</MudContainer>