@page "/admin/producto/editar/{Id}"
@rendermode InteractiveServer
@using Cafeteria.Models
@inject Cafeteria.Services.FirebaseAuthService AuthService
@inject Cafeteria.Services.AuthStateService AuthState
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
    @if (cargando)
    {
        <div class="d-flex justify-content-center">
            <MudProgressCircular Indeterminate Color="Color.Primary" />
        </div>
    }
    else if (producto == null)
    {
        <MudAlert Severity="Severity.Error">Producto no encontrado.</MudAlert>
        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick='() => Navigation.NavigateTo("/admin-tools")' Class="mt-3">
            Volver al panel
        </MudButton>
    }
    else
    {
        <MudCard Elevation="3">
            <MudCardContent>
                <div class="d-flex align-items-center mb-4">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Medium" OnClick='() => Navigation.NavigateTo("/admin-tools")' />
                    <MudText Typo="Typo.h4" Class="mb-0">✏️ Editar Producto</MudText>
                </div>
                
                <MudDivider Class="mb-4" />

                <MudGrid>
                    <!-- Nombre -->
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-1">Nombre del producto *</MudText>
                        <input type="text" class="mud-input mud-input-outlined mud-input-root" style="width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #d9d9d9;" @bind="producto.Nombre" placeholder="Ej: Café Americano" />
                    </MudItem>

                    <!-- Categoría - Seleccionar existente o nueva -->
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-1">Categoría *</MudText>
                        
                        <!-- Selector de categorías existentes -->
                        <select class="mud-input mud-input-outlined mud-input-root" style="width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #d9d9d9; margin-bottom: 10px;" @bind="categoriaSeleccionada" @bind:event="oninput" @onchange="CambiarCategoria">
                            <option value="">-- Selecciona una categoría existente --</option>
                            @foreach (var cat in categoriasExistentes)
                            {
                                <option value="@cat">@cat</option>
                            }
                            <option value="__OTRA__">-- Escribir nueva categoría --</option>
                        </select>

                        <!-- Input para nueva categoría (se muestra solo cuando se selecciona "Otra") -->
                        @if (mostrarNuevaCategoria)
                        {
                            <input type="text" class="mud-input mud-input-outlined mud-input-root" style="width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #d9d9d9; margin-top: 8px;" @bind="nuevaCategoria" placeholder="Escribe la nueva categoría" />
                        }
                    </MudItem>

                    <!-- Precio -->
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-1">Precio *</MudText>
                        <input type="number" step="0.01" min="0" class="mud-input mud-input-outlined mud-input-root" style="width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #d9d9d9;" @bind="producto.Precio" placeholder="0.00" />
                    </MudItem>

                    <!-- Descripción -->
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-1">Descripción</MudText>
                        <textarea class="mud-input mud-input-outlined mud-input-root" rows="3" style="width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #d9d9d9;" @bind="producto.Descripcion" placeholder="Descripción breve del producto"></textarea>
                    </MudItem>

                    <!-- URL Imagen -->
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-1">URL de la imagen</MudText>
                        <input type="text" class="mud-input mud-input-outlined mud-input-root" style="width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #d9d9d9;" @bind="producto.ImagenUrl" placeholder="https://ejemplo.com/imagen.jpg" />
                        @if (!string.IsNullOrEmpty(producto.ImagenUrl))
                        {
                            <div class="mt-2">
                                <img src="@producto.ImagenUrl" style="max-width: 100%; max-height: 100px; border-radius: 8px;" onerror="this.style.display='none'" />
                            </div>
                        }
                    </MudItem>

                    <!-- Disponibilidad -->
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                            <input type="checkbox" @bind="producto.Disponible" style="width: 18px; height: 18px; cursor: pointer;" />
                            <MudText Typo="Typo.body1">Producto disponible para la venta</MudText>
                        </label>
                    </MudItem>

                    <!-- Personalizaciones -->
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Personalizaciones</MudText>

                        @for (int i = 0; i < personalizacionesTemp.Count; i++)
                        {
                            var index = i;
                            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                                <input type="text" class="mud-input mud-input-outlined mud-input-root" style="flex: 1; padding: 10px; border-radius: 4px; border: 1px solid #d9d9d9;" @bind="personalizacionesTemp[index]" placeholder="Ej: sin cebolla" />
                                <button type="button" style="background: none; border: none; color: #f44336; cursor: pointer; font-size: 24px;" @onclick="@(() => EliminarPersonalizacion(index))">×</button>
                            </div>
                        }

                        <button type="button" class="mud-button mud-button-outlined mud-button-outlined-primary mud-button-root" style="width: 100%; padding: 10px; margin-top: 8px;" @onclick="AgregarPersonalizacion">
                            + Agregar personalización
                        </button>
                    </MudItem>

                    <MudItem xs="12">
                        <MudDivider Class="my-3" />
                    </MudItem>

                    <!-- Botones -->
                    <MudItem xs="6">
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="Cancelar" FullWidth="true">
                            Cancelar
                        </MudButton>
                    </MudItem>
                    <MudItem xs="6">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GuardarCambios" FullWidth="true" Disabled="@guardando">
                            @(guardando ? "Guardando..." : "Guardar cambios")
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    }
</MudContainer>

@code {
    [Parameter] public string Id { get; set; } = "";
    
    private Producto? producto = null;
    private List<string> personalizacionesTemp = new();
    private List<string> categoriasExistentes = new();
    private string categoriaSeleccionada = "";
    private string nuevaCategoria = "";
    private bool mostrarNuevaCategoria = false;
    private bool cargando = true;
    private bool guardando = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarCategoriasExistentes();
        await CargarProducto();
    }

    private async Task CargarCategoriasExistentes()
    {
        var productos = await AuthService.ObtenerProductos();
        categoriasExistentes = productos.Select(p => p.Categoria).Distinct().ToList();
    }

    private async Task CargarProducto()
    {
        cargando = true;
        producto = await AuthService.ObtenerProductoPorId(Id);
        
        if (producto != null)
        {
            personalizacionesTemp = new List<string>(producto.Personalizaciones);
            
            // Inicializar selector con la categoría actual
            categoriaSeleccionada = producto.Categoria;
            mostrarNuevaCategoria = false;
        }
        
        cargando = false;
        StateHasChanged();
    }

    private void CambiarCategoria(ChangeEventArgs e)
    {
        categoriaSeleccionada = e.Value?.ToString() ?? "";
        
        if (categoriaSeleccionada == "__OTRA__")
        {
            mostrarNuevaCategoria = true;
            if (producto != null) producto.Categoria = "";
        }
        else
        {
            mostrarNuevaCategoria = false;
            if (producto != null) producto.Categoria = categoriaSeleccionada;
            nuevaCategoria = "";
        }
    }

    private void AgregarPersonalizacion()
    {
        personalizacionesTemp.Add("");
    }

    private void EliminarPersonalizacion(int index)
    {
        personalizacionesTemp.RemoveAt(index);
    }

    private async Task GuardarCambios()
    {
        if (producto == null) return;
        
        // Validar nombre
        if (string.IsNullOrWhiteSpace(producto.Nombre))
        {
            Console.WriteLine("❌ Error: El nombre es obligatorio");
            return;
        }
        
        // Validar categoría
        string categoriaFinal = "";
        if (mostrarNuevaCategoria && !string.IsNullOrWhiteSpace(nuevaCategoria))
        {
            categoriaFinal = nuevaCategoria;
        }
        else if (!string.IsNullOrWhiteSpace(categoriaSeleccionada) && categoriaSeleccionada != "__OTRA__")
        {
            categoriaFinal = categoriaSeleccionada;
        }
        
        if (string.IsNullOrWhiteSpace(categoriaFinal))
        {
            Console.WriteLine("❌ Error: La categoría es obligatoria");
            return;
        }
        
        producto.Categoria = categoriaFinal;
        
        // Validar precio
        if (producto.Precio <= 0)
        {
            Console.WriteLine("❌ Error: El precio debe ser mayor a 0");
            return;
        }
        
        // Filtrar personalizaciones vacías
        var personalizacionesFiltradas = personalizacionesTemp
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .ToList();
        
        guardando = true;
        StateHasChanged();
        
        var exito = await AuthService.ActualizarProducto(
            id: producto.Id,
            nombre: producto.Nombre,
            descripcion: producto.Descripcion ?? "",
            precio: producto.Precio,
            categoria: producto.Categoria,
            disponible: producto.Disponible,
            imagenUrl: producto.ImagenUrl ?? "",
            personalizaciones: personalizacionesFiltradas
        );
        
        guardando = false;
        
        if (exito)
        {
            Console.WriteLine($"✅ Producto actualizado: {producto.Nombre}");
            Navigation.NavigateTo("/");
        }
        else
        {
            Console.WriteLine("❌ Error al actualizar el producto");
        }
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/admin-tools");
    }
}