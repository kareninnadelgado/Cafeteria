@page "/admin/producto/editar/{Id}"
@rendermode InteractiveServer
@using Cafeteria.Models
@inject Cafeteria.Services.FirebaseAuthService AuthService
@inject Cafeteria.Services.AuthStateService AuthState
@inject NavigationManager Navigation

<MudThemeProvider />
<MudLayout>
    <MudContainer MaxWidth="MaxWidth.Small" Class="py-4">
        @if (cargando)
        {
            <div class="d-flex justify-content-center mt-8">
                <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Default" Class="mt-3 text-center">
                    Cargando producto...
                </MudText>
            </div>
        }
        else if (producto == null)
        {
            <MudPaper Class="pa-6 text-center" Style="border-radius: 20px;">
                <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Large" Color="Color.Error" Class="mb-3" Style="font-size: 64px;" />
                <MudText Typo="Typo.h4" Color="Color.Error" Class="mb-2 font-weight-bold">
                    Producto no encontrado
                </MudText>
                <MudText Typo="Typo.body1" Color="Color.Default" Class="mb-4">
                    El producto que buscas no existe o ha sido eliminado.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick='() => Navigation.NavigateTo("/admin-tools")' Size="Size.Large">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Class="mr-2" /> Volver al panel
                </MudButton>
            </MudPaper>
        }
        else
        {
            <MudCard Elevation="3" Style="border-radius: 20px; overflow: hidden;">
                <MudCardContent Class="pa-6">
                    <MudStack AlignItems="AlignItems.Center" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Large" Style="font-size: 48px;" />
                        <MudText Typo="Typo.h4" Class="font-weight-bold">Editar Producto</MudText>
                        <MudText Typo="Typo.subtitle2" Color="Color.Default">Modifica la información del producto</MudText>
                    </MudStack>

                    <MudDivider Class="my-4" />

                    <MudGrid Spacing="3">
                        <!-- Nombre -->
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">Nombre del producto *</MudText>
                            <MudTextField T="string" 
                                          @bind-Value="producto.Nombre"
                                          Placeholder="Ej: Café Americano"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          Immediate="true" />
                        </MudItem>

                        <!-- Categoría - Seleccionar existente o nueva -->
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">Categoría *</MudText>
                            
                            <!-- Selector de categorías existentes -->
                            <select class="mud-input mud-input-outlined mud-input-root" style="width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #d9d9d9; margin-bottom: 10px;" @bind="categoriaSeleccionada" @bind:event="oninput" @onchange="CambiarCategoria">
                                <option value="">-- Selecciona una categoría existente --</option>
                                @foreach (var cat in categoriasExistentes)
                                {
                                    <option value="@cat">@cat</option>
                                }
                                <option value="__OTRA__">-- Escribir nueva categoría --</option>
                            </select>

                            @if (mostrarNuevaCategoria)
                            {
                                <MudTextField T="string" 
                                              @bind-Value="nuevaCategoria"
                                              Placeholder="Escribe la nueva categoría"
                                              Variant="Variant.Outlined"
                                              FullWidth="true"
                                              Class="mt-3" />
                            }
                        </MudItem>

                        <!-- Precio -->
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-1">Precio *</MudText>
                            <input type="number" step="0.01" min="0" class="mud-input mud-input-outlined mud-input-root" style="width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #d9d9d9;" @bind="producto.Precio" placeholder="0.00" />
                        </MudItem>

                        <!-- Descripción -->
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">Descripción</MudText>
                            <MudTextField T="string" 
                                          @bind-Value="producto.Descripcion"
                                          Placeholder="Descripción breve del producto"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          Lines="3" />
                        </MudItem>

                        <!-- URL Imagen -->
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">URL de la imagen</MudText>
                            <MudTextField T="string" 
                                          @bind-Value="producto.ImagenUrl"
                                          Placeholder="https://ejemplo.com/imagen.jpg"
                                          Variant="Variant.Outlined"
                                          FullWidth="true" />
                            
                            @if (!string.IsNullOrEmpty(producto.ImagenUrl))
                            {
                                <div class="mt-2">
                                    <img src="@producto.ImagenUrl" style="max-width: 100%; max-height: 100px; border-radius: 8px;" onerror="this.style.display='none'" />
                                </div>
                            }
                        </MudItem>

                        <!-- Disponibilidad -->
                        <MudItem xs="12">
                            <label>
                                <input type="checkbox" @bind="producto.Disponible" />
                                Producto disponible para la venta
                            </label>
                        </MudItem>

                        <!-- Personalizaciones -->
                        <MudItem xs="12">
                            <MudDivider Class="my-3" />
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">Personalizaciones</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-3">
                                Opciones que el cliente puede seleccionar (ej: sin cebolla, sin azúcar)
                            </MudText>

                            @for (int i = 0; i < personalizacionesTemp.Count; i++)
                            {
                                var index = i;
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mb-2">
                                    <MudTextField T="string" 
                                                  @bind-Value="personalizacionesTemp[index]"
                                                  Placeholder="Ej: sin cebolla"
                                                  Variant="Variant.Outlined"
                                                  FullWidth="true" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                   Size="Size.Small" 
                                                   Color="Color.Error"
                                                   OnClick="@(() => EliminarPersonalizacion(index))" />
                                </MudStack>
                            }

                            <MudButton Variant="Variant.Outlined" 
                                       Color="Color.Primary" 
                                       OnClick="AgregarPersonalizacion"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       FullWidth="true"
                                       Class="mt-2">
                                Agregar personalización
                            </MudButton>
                        </MudItem>

                        <MudItem xs="12">
                            <MudDivider Class="my-3" />
                        </MudItem>

                        <!-- Botones -->
                        <MudItem xs="6">
                            <MudButton Variant="Variant.Outlined" 
                                       Color="Color.Default" 
                                       OnClick="Cancelar" 
                                       FullWidth="true"
                                       Size="Size.Large">
                                Cancelar
                            </MudButton>
                        </MudItem>
                        <MudItem xs="6">
                            <MudButton Variant="Variant.Filled" 
                                       Color="Color.Primary" 
                                       OnClick="GuardarCambios" 
                                       FullWidth="true" 
                                       Disabled="@guardando"
                                       Size="Size.Large">
                                @(guardando ? "Guardando..." : "Guardar cambios")
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        }
    </MudContainer>
</MudLayout>

<MudSnackbarProvider />

<style>
    /* Focus visible para accesibilidad */
    .mud-button-root:focus-visible,
    .mud-input-root:focus-visible {
        outline: 2px solid var(--mud-palette-primary);
        outline-offset: 2px;
    }
</style>

@code {
    [Parameter] public string Id { get; set; } = "";
    
    private Producto? producto = null;
    private List<string> personalizacionesTemp = new();
    private List<string> categoriasExistentes = new();
    private string categoriaSeleccionada = "";
    private string nuevaCategoria = "";
    private bool mostrarNuevaCategoria = false;
    private bool cargando = true;
    private bool guardando = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarCategoriasExistentes();
        await CargarProducto();
    }

    private async Task CargarCategoriasExistentes()
    {
        var productos = await AuthService.ObtenerProductos();
        categoriasExistentes = productos.Select(p => p.Categoria).Distinct().ToList();
    }

    private async Task CargarProducto()
    {
        cargando = true;
        producto = await AuthService.ObtenerProductoPorId(Id);
        
        if (producto != null)
        {
            personalizacionesTemp = new List<string>(producto.Personalizaciones);
            
            // Inicializar selector con la categoría actual
            categoriaSeleccionada = producto.Categoria;
            mostrarNuevaCategoria = false;
        }
        
        cargando = false;
        StateHasChanged();
    }

    private void CambiarCategoria(ChangeEventArgs e)
    {
        categoriaSeleccionada = e.Value?.ToString() ?? "";
        
        if (categoriaSeleccionada == "__OTRA__")
        {
            mostrarNuevaCategoria = true;
            if (producto != null) producto.Categoria = "";
        }
        else
        {
            mostrarNuevaCategoria = false;
            if (producto != null) producto.Categoria = categoriaSeleccionada;
            nuevaCategoria = "";
        }
    }

    private void AgregarPersonalizacion()
    {
        personalizacionesTemp.Add("");
    }

    private void EliminarPersonalizacion(int index)
    {
        personalizacionesTemp.RemoveAt(index);
    }

    private async Task GuardarCambios()
    {
        if (producto == null) return;
        
        // Validar nombre
        if (string.IsNullOrWhiteSpace(producto.Nombre))
        {
            Console.WriteLine("❌ Error: El nombre es obligatorio");
            return;
        }
        
        // Validar categoría
        string categoriaFinal = "";
        if (mostrarNuevaCategoria && !string.IsNullOrWhiteSpace(nuevaCategoria))
        {
            categoriaFinal = nuevaCategoria;
        }
        else if (!string.IsNullOrWhiteSpace(categoriaSeleccionada) && categoriaSeleccionada != "__OTRA__")
        {
            categoriaFinal = categoriaSeleccionada;
        }
        
        if (string.IsNullOrWhiteSpace(categoriaFinal))
        {
            Console.WriteLine("❌ Error: La categoría es obligatoria");
            return;
        }
        
        producto.Categoria = categoriaFinal;
        
        // Validar precio
        if (producto.Precio <= 0)
        {
            Console.WriteLine("❌ Error: El precio debe ser mayor a 0");
            return;
        }
        
        // Filtrar personalizaciones vacías
        var personalizacionesFiltradas = personalizacionesTemp
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .ToList();
        
        guardando = true;
        StateHasChanged();
        
        var exito = await AuthService.ActualizarProducto(
            id: producto.Id,
            nombre: producto.Nombre,
            descripcion: producto.Descripcion ?? "",
            precio: producto.Precio,
            categoria: producto.Categoria,
            disponible: producto.Disponible,
            imagenUrl: producto.ImagenUrl ?? "",
            personalizaciones: personalizacionesFiltradas
        );
        
        guardando = false;
        
        if (exito)
        {
            Console.WriteLine($"✅ Producto actualizado: {producto.Nombre}");
            Navigation.NavigateTo("/");
        }
        else
        {
            Console.WriteLine("❌ Error al actualizar el producto");
        }
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/admin-tools");
    }
}