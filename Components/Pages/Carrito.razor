@page "/carrito"
@rendermode InteractiveServer
@using Cafeteria.Models
@using Cafeteria.Services
@inject CarritoStateService CarritoService
@inject AuthStateService AuthState
@inject Cafeteria.Services.FirebaseAuthService FirestoreService
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true" Style="font-weight: bold;">Productos de tu carrito</MudText>

    @if (AuthState.IsLoading)
    {
        <div class="d-flex flex-column align-center mt-10">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.h6" Class="mt-4">Cargando tus productos...</MudText>
        </div>
    }
    else if (CarritoService.Items == null || !CarritoService.Items.Any())
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4" Style="border-radius: 15px;">
            Parece que tu carrito está vacío. ¡Ve al menú y añade algo delicioso!
        </MudAlert>
    }
    else
    {
        <MudPaper Elevation="0" Class="pa-4" Style="background: transparent;">
            @foreach (var item in CarritoService.Items)
            {
                <MudCard Elevation="2" Class="mb-4" Style="border-radius: 20px; overflow: hidden;">
                    <MudCardContent>
                        <div class="d-flex align-center">
                            @* Imagen del producto *@
                            <MudImage Src="@item.ImagenUrl" Width="100" Height="100" Alt="@item.Nombre" 
                                      Class="rounded-lg mr-4" ObjectFit="ObjectFit.Cover" />
                            
                            @* Información del producto *@
                            <div style="flex-grow: 1;">
                                <MudText Typo="Typo.h6">@item.Nombre</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @item.Precio.ToString("C") x @item.Cantidad
                                </MudText>
                                
                                @* Personalizaciones (Chips) *@
                                @if (item.Personalizaciones != null && item.Personalizaciones.Any())
                                {
                                    <div class="mt-2">
                                        @foreach (var p in item.Personalizaciones)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" 
                                                     Variant="Variant.Text" Class="mr-1">@p</MudChip>
                                        }
                                    </div>
                                }
                            </div>

                            @* Subtotal y acciones *@
                            <div class="text-right ml-4">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: bold;">
                                    @item.Subtotal.ToString("C")
                                </MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" 
                                               OnClick="@(() => EliminarProducto(item.ProductoId))" 
                                               Title="Eliminar del carrito" />
                            </div>
                        </div>
                    </MudCardContent>
                </MudCard>
            }

            @* Resumen de Pago *@
            <MudPaper Elevation="4" Class="pa-6 mt-6" Style="border-radius: 20px; background-color: var(--mud-palette-surface);">
                <div class="d-flex justify-space-between align-center mb-4">
                    <MudText Typo="Typo.h5">Total a Pagar</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: 900;">
                        @CarritoService.TotalPagar.ToString("C")
                    </MudText>
                </div>
                <MudButton Variant="Variant.Filled" 
                        Color="Color.Primary" 
                        FullWidth="true" 
                        Size="Size.Large" 
                        Style="border-radius: 12px; height: 56px; font-weight: bold;"
                        Disabled="@_procesandoPedido"
                        OnClick="FinalizarPedidoAsync">
                    @if (_procesandoPedido)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ms-2">PROCESANDO PEDIDO...</MudText>
                    }
                    else
                    {
                        <MudText>FINALIZAR PEDIDO</MudText>
                    }
                </MudButton>
            </MudPaper>
        </MudPaper>
    }
</MudContainer>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    
    private bool _cargandoDatos = true;
    private bool _procesandoPedido = false;

    protected override async Task OnInitializedAsync()
    {
        CarritoService.OnCarritoCambiado += OnNotify;
        AuthState.OnChange += OnNotify;
        
        await CargarCarrito();
    }

    private async Task CargarCarrito()
    {
        if (AuthState.IsAuthenticated && !string.IsNullOrEmpty(AuthState.CurrentUserId))
        {
            _cargandoDatos = true;
            await CarritoService.InicializarCarritoAsync(AuthState.CurrentUserId);
            _cargandoDatos = false;
        }
        else if (!AuthState.IsLoading)
        {
            _cargandoDatos = false;
        }
    }

    private async void OnNotify()
    {
        await InvokeAsync(async () => {
            if (CarritoService.Items.Count == 0 && AuthState.IsAuthenticated)
            {
                await CargarCarrito();
            }
            StateHasChanged();
        });
    }

    private async Task EliminarProducto(string productoId)
    {
        await CarritoService.ModificarCantidadAsync(AuthState.CurrentUserId ?? "", productoId, 0);
    }

    private async Task FinalizarPedidoAsync()
    {
        if (CarritoService.Items == null || !CarritoService.Items.Any())
        {
            Snackbar.Add("El carrito está vacío.", Severity.Warning);
            return;
        }

        try
        {
            _procesandoPedido = true;
            StateHasChanged();

            string uid = AuthState.CurrentUserId ?? "anonimo";
            string clienteEmail = AuthState.CurrentUserEmail ?? "Estudiante UCOL";

            // 1. Persistencia oficial del Ticket en Firestore NoSQL
            bool guardadoExitoso = await FirestoreService.CrearTicketPedidoAsync(
                uid, 
                clienteEmail, 
                CarritoService.Items, 
                CarritoService.TotalPagar
            );

            if (!guardadoExitoso)
            {
                Snackbar.Add("Hubo un problema al registrar el pedido en el servidor. Inténtalo de nuevo.", Severity.Error);
                _procesandoPedido = false;
                return;
            }

            // 2. Construcción de la comanda para envío de salida vía WhatsApp
            string numeroCafeteria = "523121683624";
            var sb = new System.Text.StringBuilder();
            sb.AppendLine("*NUEVO PEDIDO*");
            sb.AppendLine("#id: " + Guid.NewGuid().ToString("N").Substring(0, 8).ToUpper());
            sb.AppendLine($"*Cliente:* {clienteEmail}");
            sb.AppendLine("*Productos:*");

            foreach (var item in CarritoService.Items)
            {
                sb.AppendLine($"*• {item.Cantidad}x* {item.Nombre} (Subtotal: {item.Subtotal.ToString("C")})");
                if (item.Personalizaciones != null && item.Personalizaciones.Any())
                {
                    sb.AppendLine($"   _Opciones: {string.Join(", ", item.Personalizaciones)}_");
                }
                sb.AppendLine();
            }

            sb.AppendLine("==========================================");
            sb.AppendLine($"*Total Neto a Pagar:* {CarritoService.TotalPagar.ToString("C")}");

            string mensajeUrl = Uri.EscapeDataString(sb.ToString());
            string urlWhatsApp = $"https://api.whatsapp.com/send?phone={numeroCafeteria}&text={mensajeUrl}";

            // 3. Limpieza inmediata del carrito local y en la nube
            await CarritoService.VaciarCarritoAsync(uid);
            Snackbar.Add("¡Pedido registrado con éxito!", Severity.Success);

            // 4. Interoperabilidad JS para abrir pasarela externa
            await JS.InvokeVoidAsync("open", urlWhatsApp, "_blank");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error en el flujo de checkout: {ex.Message}");
            Snackbar.Add("Ocurrió un error inesperado al finalizar el pedido.", Severity.Error);
        }
        finally
        {
            _procesandoPedido = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        CarritoService.OnCarritoCambiado -= OnNotify;
        AuthState.OnChange -= OnNotify;
    }
}