@page "/carrito"
@rendermode InteractiveServer
@using Cafeteria.Models
@using Cafeteria.Services
@inject CarritoStateService CarritoService
@inject AuthStateService AuthState
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true" Style="font-weight: bold;">Productos de tu carrito</MudText>

    @if (AuthState.IsLoading)
    {
        <div class="d-flex flex-column align-center mt-10">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.h6" Class="mt-4">Cargando tus productos...</MudText>
        </div>
    }
    else if (CarritoService.Items == null || !CarritoService.Items.Any())
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4" Style="border-radius: 15px;">
            Parece que tu carrito está vacío. ¡Ve al menú y añade algo delicioso!
        </MudAlert>
    }
    else
    {
        <MudPaper Elevation="0" Class="pa-4" Style="background: transparent;">
            @foreach (var item in CarritoService.Items)
            {
                <MudCard Elevation="2" Class="mb-4" Style="border-radius: 20px; overflow: hidden;">
                    <MudCardContent>
                        <div class="d-flex align-center">
                            @* Imagen del producto *@
                            <MudImage Src="@item.ImagenUrl" Width="100" Height="100" Alt="@item.Nombre" 
                                      Class="rounded-lg mr-4" ObjectFit="ObjectFit.Cover" />
                            
                            @* Información del producto *@
                            <div style="flex-grow: 1;">
                                <MudText Typo="Typo.h6">@item.Nombre</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @item.Precio.ToString("C") x @item.Cantidad
                                </MudText>
                                
                                @* Personalizaciones (Chips) *@
                                @if (item.Personalizaciones != null && item.Personalizaciones.Any())
                                {
                                    <div class="mt-2">
                                        @foreach (var p in item.Personalizaciones)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" 
                                                     Variant="Variant.Text" Class="mr-1">@p</MudChip>
                                        }
                                    </div>
                                }
                            </div>

                            @* Subtotal y acciones *@
                            <div class="text-right ml-4">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: bold;">
                                    @item.Subtotal.ToString("C")
                                </MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" 
                                               OnClick="@(() => EliminarProducto(item.ProductoId))" 
                                               Title="Eliminar del carrito" />
                            </div>
                        </div>
                    </MudCardContent>
                </MudCard>
            }

            @* Resumen de Pago *@
            <MudPaper Elevation="4" Class="pa-6 mt-6" Style="border-radius: 20px; background-color: var(--mud-palette-surface);">
                <div class="d-flex justify-space-between align-center mb-4">
                    <MudText Typo="Typo.h5">Total a Pagar</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: 900;">
                        @CarritoService.TotalPagar.ToString("C")
                    </MudText>
                </div>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" 
                           Size="Size.Large" Style="border-radius: 12px; height: 56px; font-weight: bold;">
                    FINALIZAR PEDIDO
                </MudButton>
            </MudPaper>
        </MudPaper>
    }
</MudContainer>

@code {
    private bool _cargandoDatos = true;

    protected override async Task OnInitializedAsync()
    {
        CarritoService.OnCarritoCambiado += OnNotify;
        AuthState.OnChange += OnNotify;
        
        await CargarCarrito();
    }

    private async Task CargarCarrito()
    {
        if (AuthState.IsAuthenticated && !string.IsNullOrEmpty(AuthState.CurrentUserId))
        {
            _cargandoDatos = true;
            await CarritoService.InicializarCarritoAsync(AuthState.CurrentUserId);
            _cargandoDatos = false;
        }
        else if (!AuthState.IsLoading)
        {
            _cargandoDatos = false;
        }
    }

    private async void OnNotify()
    {
        await InvokeAsync(async () => {
            if (CarritoService.Items.Count == 0 && AuthState.IsAuthenticated)
            {
                await CargarCarrito();
            }
            StateHasChanged();
        });
    }

    private async Task EliminarProducto(string productoId)
    {
        await CarritoService.ModificarCantidadAsync(AuthState.CurrentUserId ?? "", productoId, 0);
    }

    public void Dispose()
    {
        // Desvincular el evento para evitar fugas de memoria
        CarritoService.OnCarritoCambiado -= OnNotify;
        AuthState.OnChange -= OnNotify;
    }
}