@page "/menu"
@rendermode InteractiveServer
@using Cafeteria.Models
@inject Cafeteria.Services.FirebaseAuthService AuthService
@inject NavigationManager Navigation
@inject Cafeteria.Services.AuthStateService AuthState
@inject IJSRuntime JS

<MudThemeProvider />
<MudLayout>
    <MudContainer MaxWidth="MaxWidth.Large" Class="py-4">
        
        <!-- Header con navegación Material -->
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" 
                           Size="Size.Medium" 
                           Color="Color.Default"
                           OnClick='() => Navigation.NavigateTo("/")' />
            
            @if (!string.IsNullOrEmpty(categoriaFiltro))
            {
                <MudText Typo="Typo.h4" Class="font-weight-medium">
                    @categoriaFiltro
                </MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                    @productos.Count productos
                </MudChip>
            }
            else
            {
                <MudText Typo="Typo.h4" Class="font-weight-medium">
                    Nuestro Menú
                </MudText>
            }
        </MudStack>

        <!-- Loading State -->
        @if (cargando)
        {
            <div class="d-flex justify-content-center mt-8">
                <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Large" />
            </div>
        }
        else if (productos.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">
                <MudIcon Icon="@Icons.Material.Filled.Info" /> No hay productos disponibles en esta categoría.
            </MudAlert>
        }
        else
        {
            <!-- Grid Material Design con espaciado de 8dp -->
            <MudGrid Spacing="3" Justify="Justify.FlexStart">
                @foreach (var producto in productos)
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <MudCard Elevation="2" 
                                 ElevationHover="6"
                                 Class="product-card h-100 d-flex flex-column"
                                 Style="border-radius: 16px; cursor: pointer; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);"
                                 @onclick="() => VerDetalle(producto)">
                            
                            <!-- Media con ratio Material (16:9) -->
                            @if (!string.IsNullOrEmpty(producto.ImagenUrl))
                            {
                                <MudCardMedia Image="@producto.ImagenUrl" 
                                              Height="160" 
                                              Style="object-fit: cover;" />
                            }
                            else
                            {
                                <div class="product-placeholder text-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Fastfood" 
                                             Size="Size.Large" 
                                             Color="Color.Default" />
                                </div>
                            }
                            
                            <MudCardContent Class="flex-grow-1">
                                <!-- Título -->
                                <MudText Typo="Typo.h6" Class="font-weight-medium line-clamp-1">
                                    @producto.Nombre
                                </MudText>
                                
                                <!-- Descripción truncada -->
                                <MudText Typo="Typo.body2" Color="Color.Default" Class="mt-1 line-clamp-2">
                                    @TruncarDescripcion(producto.Descripcion)
                                </MudText>
                                
                                <!-- Precio destacado -->
                                <MudText Typo="Typo.h6" Color="Color.Primary" Class="mt-2 font-weight-bold">
                                    $@producto.Precio.ToString("0.00")
                                </MudText>
                                
                                <!-- Chips (categoría y disponibilidad) -->
                                <MudStack Row="true" Spacing="1" Class="mt-2 flex-wrap">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled">
                                        @producto.Categoria
                                    </MudChip>
                                    
                                    @if (producto.Disponible)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" /> Disponible
                                        </MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">
                                            <MudIcon Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" /> No disponible
                                        </MudChip>
                                    }
                                </MudStack>
                                
                                <!-- Botones de admin -->
                                @if (esAdmin)
                                {
                                    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1" Class="mt-3">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                                       Size="Size.Small" 
                                                       Color="Color.Info"
                                                       OnClick="@(() => EditarProducto(producto))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                       Size="Size.Small" 
                                                       Color="Color.Error"
                                                       OnClick="@(() => ConfirmarEliminar(producto))" />
                                    </MudStack>
                                }
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudContainer>
</MudLayout>

<MudSnackbarProvider />

<style>
    /* Estilos Material Design complementarios */
    .product-card {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
    }
    
    .product-card:active {
        transform: scale(0.98);
    }
    
    .product-placeholder {
        height: 160px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--mud-palette-action-default-hover);
    }
    
    /* Utilidades de truncado */
    .line-clamp-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    
    /* Focus visible para accesibilidad */
    .product-card:focus-visible,
    .mud-icon-button:focus-visible {
        outline: 2px solid var(--mud-palette-primary);
        outline-offset: 2px;
    }
</style>

@code {
    [Parameter] public string? Categoria { get; set; }
    private bool esAdmin = false;
    private bool verificandoAdmin = true;
    private List<Producto> productos = new();
    private bool cargando = true;
    private string categoriaFiltro = "";

    protected override async Task OnInitializedAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("categoria", out var categoriaValue))
        {
            categoriaFiltro = categoriaValue.ToString();
        }
        
        await CargarProductos();
    }

    private async Task CargarProductos()
    {
        cargando = true;
        var todosLosProductos = await AuthService.ObtenerProductos();
        
        if (!string.IsNullOrEmpty(categoriaFiltro))
        {
            productos = todosLosProductos.Where(p => p.Categoria == categoriaFiltro).ToList();
            Console.WriteLine($"Filtrando por categoría: {categoriaFiltro}, encontrados: {productos.Count}");
        }
        else
        {
            productos = todosLosProductos;
        }
        
        cargando = false;
        StateHasChanged();
    }

    private void VerDetalle(Producto producto)
    {
        Navigation.NavigateTo($"/producto/{producto.Id}");
    }

    private string TruncarDescripcion(string descripcion)
    {
        if (string.IsNullOrEmpty(descripcion)) return "";
        if (descripcion.Length <= 80) return descripcion;
        return descripcion.Substring(0, 80) + "...";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && verificandoAdmin)
        {
            verificandoAdmin = false;
            await AuthState.CargarSesionDesdeLocalStorage();
            esAdmin = AuthState.IsAdmin;
            Console.WriteLine($"Admin en Menu.razor: {esAdmin}");
            StateHasChanged();
        }
    }
    
    private void EditarProducto(Producto producto)
    {
        Navigation.NavigateTo($"/admin/producto/editar/{producto.Id}");
    }

    private async Task ConfirmarEliminar(Producto producto)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", $"¿Eliminar {producto.Nombre}? Esta acción no se puede deshacer.");
        if (confirm)
        {
            var exito = await AuthService.EliminarProducto(producto.Id);
            if (exito)
            {
                productos.Remove(producto);
                StateHasChanged();
                Console.WriteLine($"✅ Producto eliminado: {producto.Nombre}");
            }
        }
    }
}