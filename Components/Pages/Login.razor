@page "/login"
@rendermode InteractiveServer
@using System.Text.Json
@inject Cafeteria.Services.FirebaseAuthService AuthService
@inject Cafeteria.Services.AuthStateService AuthState
@inject NavigationManager Navigation

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card p-4 shadow-sm" style="width: 100%; max-width: 400px; border-radius: 12px;">
        <h2 class="text-center mb-4">Iniciar Sesión</h2>
        
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger p-2 small text-center">@errorMessage</div>
        }

        <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />
            
            <div class="mb-3">
                <label class="form-label">Correo electrónico</label>
                <InputText @bind-Value="loginModel.Email" class="form-control" placeholder="ejemplo@correo.com" type="email" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <InputText @bind-Value="loginModel.Password" class="form-control" placeholder="******" type="password" />
            </div>
            
            <button type="submit" class="btn btn-primary w-100 fw-bold py-2 mt-2">Ingresar</button>
        </EditForm>
        
        <p class="text-center mt-4 mb-0">
            ¿No tienes cuenta? <a href="/register" class="text-decoration-none fw-bold">Regístrate aquí</a>
        </p>
    </div>
</div>

@code {
    private LoginClass loginModel = new LoginClass();
    private string errorMessage = string.Empty;

    private async Task HandleLogin()
    {
        errorMessage = string.Empty;

        var respuestaJson = await AuthService.Login(loginModel.Email, loginModel.Password);

        if (respuestaJson.Contains("idToken"))
        {
            using var doc = JsonDocument.Parse(respuestaJson);
            string uid = doc.RootElement.GetProperty("localId").GetString() ?? "";
            string email = doc.RootElement.GetProperty("email").GetString() ?? "";

            string rol = await AuthService.ObtenerRolUsuario(uid);
            
            await AuthState.SetUser(uid, email, rol);
            Console.WriteLine($"Estado guardado - IsAdmin: {AuthState.IsAdmin}");
            
            Console.WriteLine($"✅ Sesión iniciada: {email} (UID: {uid}, Rol: {rol})");
            
            // Usar NavigationManager con replace
            if (rol == "admin")
            {
                Console.WriteLine("si llega aquí el pendejo");
                await InvokeAsync(() =>
                {
                    Navigation.NavigateTo("/admin-tools", true);
                    StateHasChanged();
                });
            }
            else
            {
                await InvokeAsync(() =>
                {
                    Navigation.NavigateTo("/menu", true);
                    StateHasChanged();
                });
            }
        }
        else
        {
            errorMessage = "Credenciales incorrectas o el usuario no existe.";
            Console.WriteLine($"Error de Firebase: {respuestaJson}");
        }
    }

    public class LoginClass
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}