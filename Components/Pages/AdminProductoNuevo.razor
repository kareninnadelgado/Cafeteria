@page "/admin/producto/nuevo"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@using Cafeteria.Models
@inject Cafeteria.Services.FirebaseAuthService AuthService
@inject NavigationManager Navigation
@inject Cafeteria.Services.AuthStateService AuthState

@if (verificando)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2">Verificando acceso...</p>
    </div>
}
else if (!esAdmin)
{
    <div class="alert alert-danger py-5 text-center">
        <h3>Acceso Denegado</h3>
        <p>No tienes permisos para acceder a esta página.</p>
    </div>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
        <MudCard Elevation="3">
            <MudCardContent>
                <MudText Typo="Typo.h4" Class="mb-1">➕ Añadir Producto</MudText>
                <MudText Typo="Typo.subtitle2" Class="mb-4 text-muted">Agrega un nuevo producto al menú</MudText>

                <MudDivider Class="mb-4" />

                <MudGrid>
                    <!-- Nombre -->
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-1">Nombre del producto *</MudText>
                        <input type="text" class="mud-input mud-input-outlined mud-input-root" style="width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #d9d9d9;" @bind="nuevoProducto.Nombre" placeholder="Ej: Café Americano" />
                    </MudItem>

                    <!-- Categoría - Seleccionar existente o nueva -->
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-1">Categoría *</MudText>
                        
                        <!-- Selector de categorías existentes -->
                        <select class="mud-input mud-input-outlined mud-input-root" style="width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #d9d9d9; margin-bottom: 10px;" @bind="categoriaSeleccionada" @bind:event="oninput" @onchange="CambiarCategoria">
                            <option value="">-- Selecciona una categoría existente --</option>
                            @foreach (var cat in categoriasExistentes)
                            {
                                <option value="@cat">@cat</option>
                            }
                            <option value="__OTRA__">-- Escribir nueva categoría --</option>
                        </select>

                        <!-- Input para nueva categoría (se muestra solo cuando se selecciona "Otra") -->
                        @if (mostrarNuevaCategoria)
                        {
                            <input type="text" class="mud-input mud-input-outlined mud-input-root" style="width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #d9d9d9; margin-top: 8px;" @bind="nuevaCategoria" placeholder="Escribe la nueva categoría" />
                        }
                    </MudItem>

                    <!-- Precio -->
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-1">Precio *</MudText>
                        <input type="number" step="0.01" min="0" class="mud-input mud-input-outlined mud-input-root" style="width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #d9d9d9;" @bind="nuevoProducto.Precio" placeholder="0.00" />
                    </MudItem>

                    <!-- Descripción -->
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-1">Descripción</MudText>
                        <textarea class="mud-input mud-input-outlined mud-input-root" rows="3" style="width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #d9d9d9;" @bind="nuevoProducto.Descripcion" placeholder="Descripción breve del producto"></textarea>
                    </MudItem>

                    <!-- URL Imagen -->
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-1">URL de la imagen</MudText>
                        <input type="text" class="mud-input mud-input-outlined mud-input-root" style="width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #d9d9d9;" @bind="nuevoProducto.ImagenUrl" placeholder="https://ejemplo.com/imagen.jpg" />
                        @if (!string.IsNullOrEmpty(nuevoProducto.ImagenUrl))
                        {
                            <div class="mt-2">
                                <img src="@nuevoProducto.ImagenUrl" style="max-width: 100%; max-height: 100px; border-radius: 8px;" onerror="this.style.display='none'" />
                            </div>
                        }
                    </MudItem>

                    <!-- Disponible -->
                    <MudItem xs="12">
                        <label>
                            <input type="checkbox" @bind="nuevoProducto.Disponible" />
                            Disponible para la venta
                        </label>
                    </MudItem>

                    <!-- Personalizaciones -->
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Personalizaciones</MudText>
                        <MudText Typo="Typo.caption" Class="mb-3 text-muted">
                            Opciones que el cliente puede seleccionar (ej: sin cebolla, sin azúcar)
                        </MudText>

                        @for (int i = 0; i < listaPersonalizaciones.Count; i++)
                        {
                            var index = i;
                            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                                <input type="text" class="mud-input mud-input-outlined mud-input-root" style="flex: 1; padding: 10px; border-radius: 4px; border: 1px solid #d9d9d9;" @bind="listaPersonalizaciones[index]" placeholder="Ej: sin cebolla" />
                                <button type="button" style="background: none; border: none; color: #f44336; cursor: pointer; font-size: 24px;" @onclick="@(() => EliminarPersonalizacion(index))">×</button>
                            </div>
                        }

                        <button type="button" class="mud-button mud-button-outlined mud-button-outlined-primary mud-button-root" style="width: 100%; padding: 10px; margin-top: 8px;" @onclick="AgregarPersonalizacion">
                            + Agregar personalización
                        </button>
                    </MudItem>

                    <MudItem xs="12">
                        <MudDivider Class="my-3" />
                    </MudItem>

                    <!-- Botones -->
                    <MudItem xs="6">
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="@Cancelar" FullWidth="true">
                            Cancelar
                        </MudButton>
                    </MudItem>
                    <MudItem xs="6">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@GuardarProducto" FullWidth="true" Disabled="@cargando">
                            @(cargando ? "Guardando..." : "Guardar producto")
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>

        <MudSnackbarProvider />
    </MudContainer>
}

@code {
    private Producto nuevoProducto = new Producto();
    private List<string> listaPersonalizaciones = new List<string>();
    private List<string> categoriasExistentes = new List<string>();
    private string categoriaSeleccionada = "";
    private string nuevaCategoria = "";
    private bool mostrarNuevaCategoria = false;
    private bool cargando = false;
    private bool esAdmin = false;
    private bool verificando = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && verificando)
        {
            verificando = false;
            
            // Cargar sesión desde localStorage
            await AuthState.CargarSesionDesdeLocalStorage();
            
            if (!AuthState.IsAdmin)
            {
                Console.WriteLine("❌ No es admin, redirigiendo a menu");
                Navigation.NavigateTo("/menu", true);
                return;
            }
            
            esAdmin = true;
            await CargarCategoriasExistentes();
            StateHasChanged();
        }
    }

    private async Task CargarCategoriasExistentes()
    {
        var productos = await AuthService.ObtenerProductos();
        categoriasExistentes = productos.Select(p => p.Categoria).Distinct().ToList();
        StateHasChanged();
    }

    private void CambiarCategoria(ChangeEventArgs e)
    {
        categoriaSeleccionada = e.Value?.ToString() ?? "";
        
        if (categoriaSeleccionada == "__OTRA__")
        {
            mostrarNuevaCategoria = true;
            nuevoProducto.Categoria = "";
        }
        else
        {
            mostrarNuevaCategoria = false;
            nuevoProducto.Categoria = categoriaSeleccionada;
            nuevaCategoria = "";
        }
    }

    private void AgregarPersonalizacion()
    {
        listaPersonalizaciones.Add("");
    }

    private void EliminarPersonalizacion(int index)
    {
        listaPersonalizaciones.RemoveAt(index);
    }

    private async Task GuardarProducto()
    {
        // Validar nombre
        if (string.IsNullOrWhiteSpace(nuevoProducto.Nombre))
        {
            Console.WriteLine("❌ Error: El nombre es obligatorio");
            return;
        }

        // Validar categoría
        string categoriaFinal = "";
        if (mostrarNuevaCategoria && !string.IsNullOrWhiteSpace(nuevaCategoria))
        {
            categoriaFinal = nuevaCategoria;
        }
        else if (!string.IsNullOrWhiteSpace(categoriaSeleccionada) && categoriaSeleccionada != "__OTRA__")
        {
            categoriaFinal = categoriaSeleccionada;
        }

        if (string.IsNullOrWhiteSpace(categoriaFinal))
        {
            Console.WriteLine("❌ Error: La categoría es obligatoria");
            return;
        }

        nuevoProducto.Categoria = categoriaFinal;

        // Validar precio
        if (nuevoProducto.Precio <= 0)
        {
            Console.WriteLine("❌ Error: El precio debe ser mayor a 0");
            return;
        }

        // Filtrar personalizaciones vacías
        var personalizacionesFiltradas = listaPersonalizaciones
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .ToList();

        cargando = true;
        StateHasChanged();

        try
        {
            var exito = await AuthService.CrearProducto(
                nombre: nuevoProducto.Nombre,
                descripcion: nuevoProducto.Descripcion ?? "",
                precio: nuevoProducto.Precio,
                categoria: nuevoProducto.Categoria,
                disponible: nuevoProducto.Disponible,
                imagenUrl: nuevoProducto.ImagenUrl ?? "",
                personalizaciones: personalizacionesFiltradas
            );

            if (exito)
            {
                Console.WriteLine($"✅ Producto creado: {nuevoProducto.Nombre}");
                Navigation.NavigateTo("/admin-tools");
            }
            else
            {
                Console.WriteLine("❌ Error al crear el producto");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Excepción: {ex.Message}");
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/admin-tools");
    }
}