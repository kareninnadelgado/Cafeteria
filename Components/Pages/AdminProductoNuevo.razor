@page "/admin/producto/nuevo"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@using Cafeteria.Models
@inject Cafeteria.Services.FirebaseAuthService AuthService
@inject NavigationManager Navigation
@inject Cafeteria.Services.AuthStateService AuthState

<MudThemeProvider />
<MudLayout>
    <MudContainer MaxWidth="MaxWidth.Small" Class="py-4">
        
        @if (verificando)
        {
            <div class="d-flex justify-content-center mt-8">
                <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Default" Class="mt-3 text-center">
                    Verificando acceso...
                </MudText>
            </div>
        }
        else if (!esAdmin)
        {
            <MudPaper Class="pa-6 text-center" Style="border-radius: 20px;">
                <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Error" Class="mb-3" Style="font-size: 64px;" />
                <MudText Typo="Typo.h4" Color="Color.Error" Class="mb-2 font-weight-bold">
                    Acceso Denegado
                </MudText>
                <MudText Typo="Typo.body1" Color="Color.Default" Class="mb-4">
                    No tienes permisos para acceder a esta página.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick='() => Navigation.NavigateTo("/")' Size="Size.Large">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Class="mr-2" /> Volver al Menú
                </MudButton>
            </MudPaper>
        }
        else
        {
            <MudCard Elevation="3" Style="border-radius: 20px; overflow: hidden;">
                <MudCardContent Class="pa-6">
                    <MudStack AlignItems="AlignItems.Center" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Size="Size.Large" Style="font-size: 48px;" />
                        <MudText Typo="Typo.h4" Class="font-weight-bold">Añadir Producto</MudText>
                        <MudText Typo="Typo.subtitle2" Color="Color.Default">Agrega un nuevo producto al menú</MudText>
                    </MudStack>

                    <MudDivider Class="my-4" />

                    <MudGrid Spacing="3">
                        <!-- Nombre -->
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">Nombre del producto *</MudText>
                            <MudTextField T="string" 
                                          @bind-Value="nuevoProducto.Nombre"
                                          Placeholder="Ej: Café Americano"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          Immediate="true" />
                        </MudItem>

                        <!-- Categoría -->
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">Categoría *</MudText>
                            
                            <!-- Selector de categorías existentes -->
                            <select class="mud-input mud-input-outlined mud-input-root" style="width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #d9d9d9; margin-bottom: 10px;" @bind="categoriaSeleccionada" @bind:event="oninput" @onchange="CambiarCategoria">
                                <option value="">-- Selecciona una categoría existente --</option>
                                @foreach (var cat in categoriasExistentes)
                                {
                                    <option value="@cat">@cat</option>
                                }
                                <option value="__OTRA__">-- Escribir nueva categoría --</option>
                            </select>

                            @if (mostrarNuevaCategoria)
                            {
                                <MudTextField T="string" 
                                              @bind-Value="nuevaCategoria"
                                              Placeholder="Escribe la nueva categoría"
                                              Variant="Variant.Outlined"
                                              FullWidth="true"
                                              Class="mt-3" />
                            }
                        </MudItem>

                        <!-- Precio -->
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-1">Precio *</MudText>
                            <input type="number" step="0.01" min="0" class="mud-input mud-input-outlined mud-input-root" style="width: 100%; padding: 12px; border-radius: 4px; border: 1px solid #d9d9d9;" @bind="nuevoProducto.Precio" placeholder="0.00" />
                        </MudItem>

                        <!-- Descripción -->
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">Descripción</MudText>
                            <MudTextField T="string" 
                                          @bind-Value="nuevoProducto.Descripcion"
                                          Placeholder="Descripción breve del producto"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          Lines="3" />
                        </MudItem>

                        <!-- URL Imagen -->
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">URL de la imagen</MudText>
                            <MudTextField T="string" 
                                          @bind-Value="nuevoProducto.ImagenUrl"
                                          Placeholder="https://ejemplo.com/imagen.jpg"
                                          Variant="Variant.Outlined"
                                          FullWidth="true" />
                            
                            @if (!string.IsNullOrEmpty(nuevoProducto.ImagenUrl))
                            {
                                <div class="mt-2">
                                    <img src="@nuevoProducto.ImagenUrl" style="max-width: 100%; max-height: 100px; border-radius: 8px;" onerror="this.style.display='none'" />
                                </div>
                            }
                        </MudItem>

                        <!-- Disponible -->
                        <MudItem xs="12">
                            <label>
                                <input type="checkbox" @bind="nuevoProducto.Disponible" />
                                Disponible para la venta
                            </label>
                        </MudItem>

                        <!-- Personalizaciones -->
                        <MudItem xs="12">
                            <MudDivider Class="my-3" />
                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-medium">Personalizaciones</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-3">
                                Opciones que el cliente puede seleccionar (ej: sin cebolla, sin azúcar)
                            </MudText>

                            @for (int i = 0; i < listaPersonalizaciones.Count; i++)
                            {
                                var index = i;
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mb-2">
                                    <MudTextField T="string" 
                                                  @bind-Value="listaPersonalizaciones[index]"
                                                  Placeholder="Ej: sin cebolla"
                                                  Variant="Variant.Outlined"
                                                  FullWidth="true" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                   Size="Size.Small" 
                                                   Color="Color.Error"
                                                   OnClick="@(() => EliminarPersonalizacion(index))" />
                                </MudStack>
                            }

                            <MudButton Variant="Variant.Outlined" 
                                       Color="Color.Primary" 
                                       OnClick="AgregarPersonalizacion"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       FullWidth="true"
                                       Class="mt-2">
                                Agregar personalización
                            </MudButton>
                        </MudItem>

                        <MudItem xs="12">
                            <MudDivider Class="my-3" />
                        </MudItem>

                        <!-- Botones -->
                        <MudItem xs="6">
                            <MudButton Variant="Variant.Outlined" 
                                       Color="Color.Default" 
                                       OnClick="Cancelar" 
                                       FullWidth="true"
                                       Size="Size.Large">
                                Cancelar
                            </MudButton>
                        </MudItem>
                        <MudItem xs="6">
                            <MudButton Variant="Variant.Filled" 
                                       Color="Color.Primary" 
                                       OnClick="GuardarProducto" 
                                       FullWidth="true" 
                                       Disabled="@cargando"
                                       Size="Size.Large">
                                @(cargando ? "Guardando..." : "Guardar producto")
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        }
    </MudContainer>
</MudLayout>

<MudSnackbarProvider />

<style>
    /* Focus visible para accesibilidad */
    .mud-button-root:focus-visible,
    .mud-input-root:focus-visible {
        outline: 2px solid var(--mud-palette-primary);
        outline-offset: 2px;
    }
</style>

@code {
    private Producto nuevoProducto = new Producto();
    private List<string> listaPersonalizaciones = new List<string>();
    private List<string> categoriasExistentes = new List<string>();
    private string categoriaSeleccionada = "";
    private string nuevaCategoria = "";
    private bool mostrarNuevaCategoria = false;
    private bool cargando = false;
    private bool esAdmin = false;
    private bool verificando = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && verificando)
        {
            verificando = false;
            
            // Cargar sesión desde localStorage
            await AuthState.CargarSesionDesdeLocalStorage();
            
            if (!AuthState.IsAdmin)
            {
                Console.WriteLine("❌ No es admin, redirigiendo a menu");
                Navigation.NavigateTo("/", true);
                return;
            }
            
            esAdmin = true;
            await CargarCategoriasExistentes();
            StateHasChanged();
        }
    }

    private async Task CargarCategoriasExistentes()
    {
        var productos = await AuthService.ObtenerProductos();
        categoriasExistentes = productos.Select(p => p.Categoria).Distinct().ToList();
        StateHasChanged();
    }

    private void CambiarCategoria(ChangeEventArgs e)
    {
        categoriaSeleccionada = e.Value?.ToString() ?? "";
        
        if (categoriaSeleccionada == "__OTRA__")
        {
            mostrarNuevaCategoria = true;
            nuevoProducto.Categoria = "";
        }
        else
        {
            mostrarNuevaCategoria = false;
            nuevoProducto.Categoria = categoriaSeleccionada;
            nuevaCategoria = "";
        }
    }

    private void AgregarPersonalizacion()
    {
        listaPersonalizaciones.Add("");
    }

    private void EliminarPersonalizacion(int index)
    {
        listaPersonalizaciones.RemoveAt(index);
    }

    private async Task GuardarProducto()
    {
        // Validar nombre
        if (string.IsNullOrWhiteSpace(nuevoProducto.Nombre))
        {
            Console.WriteLine("❌ Error: El nombre es obligatorio");
            return;
        }

        // Validar categoría
        string categoriaFinal = "";
        if (mostrarNuevaCategoria && !string.IsNullOrWhiteSpace(nuevaCategoria))
        {
            categoriaFinal = nuevaCategoria;
        }
        else if (!string.IsNullOrWhiteSpace(categoriaSeleccionada) && categoriaSeleccionada != "__OTRA__")
        {
            categoriaFinal = categoriaSeleccionada;
        }

        if (string.IsNullOrWhiteSpace(categoriaFinal))
        {
            Console.WriteLine("❌ Error: La categoría es obligatoria");
            return;
        }

        nuevoProducto.Categoria = categoriaFinal;

        // Validar precio
        if (nuevoProducto.Precio <= 0)
        {
            Console.WriteLine("❌ Error: El precio debe ser mayor a 0");
            return;
        }

        // Filtrar personalizaciones vacías
        var personalizacionesFiltradas = listaPersonalizaciones
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .ToList();

        cargando = true;
        StateHasChanged();

        try
        {
            var exito = await AuthService.CrearProducto(
                nombre: nuevoProducto.Nombre,
                descripcion: nuevoProducto.Descripcion ?? "",
                precio: nuevoProducto.Precio,
                categoria: nuevoProducto.Categoria,
                disponible: nuevoProducto.Disponible,
                imagenUrl: nuevoProducto.ImagenUrl ?? "",
                personalizaciones: personalizacionesFiltradas
            );

            if (exito)
            {
                Console.WriteLine($"✅ Producto creado: {nuevoProducto.Nombre}");
                Navigation.NavigateTo("/admin-tools");
            }
            else
            {
                Console.WriteLine("❌ Error al crear el producto");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Excepción: {ex.Message}");
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/admin-tools");
    }
}