@page "/"
@rendermode InteractiveServer
@using Cafeteria.Models
@inject Cafeteria.Services.FirebaseAuthService AuthService
@inject Cafeteria.Services.AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Cafetería Escolar - Material Design</PageTitle>

<MudThemeProvider />
<MudLayout>
    <MudContainer MaxWidth="MaxWidth.Small" Class="py-4">
        <MudStack Spacing="3" Justify="Justify.Center" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h4" Align="Align.Center" Color="Color.Primary" Class="font-weight-bold">
                Cafetería Escolar
            </MudText>
            <MudText Typo="Typo.subtitle2" Align="Align.Center" Color="Color.Default">
                Selecciona una categoría
            </MudText>
        </MudStack>

        @if (cargando)
        {
            <div class="d-flex justify-content-center mt-8">
                <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Large" />
            </div>
        }
        else if (categorias.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">
                <MudIcon Icon="@Icons.Material.Filled.Info" /> No hay categorías disponibles.
            </MudAlert>
        }
        else
        {
            <MudGrid Spacing="3" Justify="Justify.Center">
                @foreach (var categoria in categorias)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard 
                            Elevation="2" 
                            ElevationHover="6"
                            Class="category-card"
                            Style="cursor: pointer; height: 100%; border-radius: 16px; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);"
                            @onclick="() => IrAMenu(categoria)">
                            
                            <MudCardContent Class="pa-6 text-center">
                                <MudIcon 
                                    Icon="@ObtenerIconoCategoria(categoria)" 
                                    Size="Size.Large" 
                                    Color="Color.Primary" 
                                    Class="mb-3" 
                                />
                                <MudText Typo="Typo.h6" Class="mb-2 font-weight-medium">
                                    @categoria
                                </MudText>
                                <MudText Typo="Typo.body2" Color="Color.Default" Class="text-muted">
                                    Ver productos →
                                </MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }

        @if (esAdmin)
        {
            <div class="text-center mt-8">
                <MudButton 
                    Variant="Variant.Filled" 
                    Color="Color.Secondary" 
                    Size="Size.Large" 
                    StartIcon="@Icons.Material.Filled.AdminPanelSettings"
                    OnClick='() => Navigation.NavigateTo("/admin-tools")'>
                    Panel de Administración
                </MudButton>
            </div>
        }
    </MudContainer>
</MudLayout>

<style>
    /* Base: 8dp grid de Material Design */
    .category-card {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
    }
    
    /* Feedback táctil (Material Design guideline) */
    .category-card:active {
        transform: scale(0.98);
    }
    
    /* Mejora de accesibilidad */
    .mud-button-root:focus-visible {
        outline: 2px solid var(--mud-palette-primary);
        outline-offset: 2px;
    }
</style>

@code {
    private List<string> categorias = new();
    private bool cargando = true;
    private bool esAdmin = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarCategorias();
    }

    private async Task CargarCategorias()
    {
        cargando = true;
        categorias = await AuthService.ObtenerCategorias();
        cargando = false;
        StateHasChanged();
    }

    private bool estadoInicializado = false;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || estadoInicializado) return;
        estadoInicializado = true;
        await AuthState.CargarSesionDesdeLocalStorage();
        esAdmin = AuthState.IsAdmin;
        StateHasChanged();
    }

    private void IrAMenu(string categoria)
    {
        Navigation.NavigateTo($"/menu?categoria={Uri.EscapeDataString(categoria)}");
    }

    private string ObtenerIconoCategoria(string categoria)
    {
        return categoria switch
        {
            "Bebidas Calientes" => Icons.Material.Filled.LocalCafe,
            "Bebidas Frias" => Icons.Material.Filled.LocalDrink,
            "Comida" => Icons.Material.Filled.LunchDining,
            "Postres" => Icons.Material.Filled.Cake,
            _ => Icons.Material.Filled.Category
        };
    }
}