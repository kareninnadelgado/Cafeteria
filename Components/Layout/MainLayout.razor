@inherits LayoutComponentBase
@implements IDisposable
@inject Cafeteria.Services.AuthStateService AuthState
@inject Cafeteria.Services.CarritoStateService CarritoService
@inject NavigationManager NavigationManager

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingValue Value="esAdmin" Name="AdminState">
    <MudLayout>
        <MudAppBar Elevation="1">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" OnClick="@DrawerToggle" />
            <MudText Typo="Typo.h6" Class="ml-2">Cafetería Escolar</MudText>
            <MudSpacer />
            
            @if (esAdmin)
            {
                <MudIconButton Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Inherit" OnClick='() => NavigationManager.NavigateTo("/admin/pedidos")' />
            }
            
            @* Carrito fijo para alumnos: se muestra fuera del AppBar (CSS position fixed) *@
            @if (AuthState.IsAuthenticated)
            {
                <!-- de momento dejamos espacio en AppBar; el botón fijo se renderiza más abajo -->
            }
        </MudAppBar>
        
        @* Botón fijo de carrito (solo alumnos) *@
        @if (AuthState.IsAuthenticated && !esAdmin)
        {
            <div class="fixed-cart">
                <MudBadge Content="@CarritoService.TotalProductos" Color="Color.Error" Overlap="true" Visible="@(CarritoService.TotalProductos > 0)">
                    <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Primary" OnClick='() => NavigationManager.NavigateTo("/carrito")' />
                </MudBadge>
            </div>
        }
        <MudDrawer @bind-Open="_drawerOpen" Elevation="2">
            <MudNavMenu>
                <MudNavLink Href="/menu" Match="NavLinkMatch.Prefix">
                    <MudIcon Icon="@Icons.Material.Filled.RestaurantMenu" /> Menú
                </MudNavLink>
                
                @if (AuthState.IsAuthenticated)
                {
                    <MudNavLink Href="/mis-pedidos">
                        <MudIcon Icon="@Icons.Material.Filled.History" /> Mis Pedidos
                    </MudNavLink>
                }
                
                @if (esAdmin)
                {
                    <MudNavLink Href="/admin/pedidos">
                        <MudIcon Icon="@Icons.Material.Filled.DeliveryDining" /> Cocina (Pedidos)
                    </MudNavLink>
                }
                
                @if (!AuthState.IsAuthenticated)
                {
                    <MudNavLink Href="/login">
                        <MudIcon Icon="@Icons.Material.Filled.Login" /> Iniciar Sesión
                    </MudNavLink>
                    <MudNavLink Href="/register">
                        <MudIcon Icon="@Icons.Material.Filled.AppRegistration" /> Registrarse
                    </MudNavLink>
                }
                else
                {
                    <MudNavLink OnClick="CerrarSesion" Style="cursor: pointer;">
                        <MudIcon Icon="@Icons.Material.Filled.Logout" /> Cerrar Sesión
                    </MudNavLink>
                }
            </MudNavMenu>
        </MudDrawer>
        
        <MudMainContent>
            <MudContainer Class="py-4">
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>
</CascadingValue>

@code {
    private bool _drawerOpen = true;
    private bool esAdmin = false;

    protected override void OnInitialized()
    {
        AuthState.OnChange += OnAuthStateChanged;
        CarritoService.OnCarritoCambiado += RederizarNavbar;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthState.CargarSesionDesdeLocalStorage();
            esAdmin = AuthState.IsAdmin;
            
            if (AuthState.IsAuthenticated)
            {
                // Sincroniza el gestor de estado con Firestore/Localstorage
                await CarritoService.InicializarCarritoAsync(AuthState.CurrentUserId!);
            }
            StateHasChanged();
        }
    }

    private void OnAuthStateChanged()
    {
        InvokeAsync(async () =>
        {
            esAdmin = AuthState.IsAdmin;
            if (AuthState.IsAuthenticated)
            {
                await CarritoService.InicializarCarritoAsync(AuthState.CurrentUserId!);
            }
            StateHasChanged();
        });
    }

    private void RederizarNavbar() => InvokeAsync(StateHasChanged);

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;
    
    private async Task CerrarSesion()
    {
        await AuthState.ClearUser();
        NavigationManager.NavigateTo("/login", true);
    }

    public void Dispose()
    {
        AuthState.OnChange -= OnAuthStateChanged;
        CarritoService.OnCarritoCambiado -= RederizarNavbar;
    }
}

<style>
    .fixed-cart {
        position: fixed;
        top: 12px;
        right: 12px;
        z-index: 2000;
    }

    @@media (max-width: 576px) {
        .fixed-cart { top: 8px; right: 8px; }
    }
</style>