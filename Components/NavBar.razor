@inject Cafeteria.Services.AuthStateService AuthState
@inject NavigationManager NavigationManager

<MudAppBar Elevation="1">
    <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" OnClick="@OnMenuClick" />
    <MudText Typo="Typo.h6" Class="ml-2">Cafetería Escolar</MudText>
    <MudSpacer />
    
    @if (esAdmin)
    {
        <MudIconButton Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Inherit" OnClick='() => NavigationManager.NavigateTo("/admin-tools")' />
    }
    
    <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Inherit" />
</MudAppBar>

@code {
    [Parameter] public EventCallback OnMenuClick { get; set; }
    
    private bool esAdmin = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Recargar el estado de admin cada vez que se renderiza
        esAdmin = AuthState.IsAdmin;
        
        // Si no hay datos, forzar carga
        if (string.IsNullOrEmpty(AuthState.CurrentUserId))
        {
            await AuthState.CargarSesionDesdeLocalStorage();
            esAdmin = AuthState.IsAdmin;
        }
        
        StateHasChanged();
    }
}